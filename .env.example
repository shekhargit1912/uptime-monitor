# Copy to .env to override defaults. docker-compose.yml falls back to these
# same values when no .env is present, so the stack works out-of-the-box.

# How often (in seconds) every monitored URL is pinged
CHECK_INTERVAL=60

# Storage: SQLite. The database file is kept on the `sqlitedata` Docker volume
# (mounted at /data in the backend container), so data persists across restarts.
# No database credentials are needed.
